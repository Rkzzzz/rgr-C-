```gitignore
# Database files
*.sqlite

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment files
.env
.env.local
*.env.*

# Logs
*.log

# Temporary files
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/
*.swp
*.swo

# Coverage reports
.coverage
coverage/
htmlcov/

# Distribution / packaging
dist/
build/
*.egg-info/
```